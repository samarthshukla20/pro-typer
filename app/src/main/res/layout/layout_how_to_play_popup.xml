<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="32dp"
    android:background="@android:color/transparent"
    app:cardPreventCornerOverlap="false"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_card"
    app:strokeColor="@color/pro_blue_primary"
    app:strokeWidth="2dp"
    app:contentPadding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHeadingPopup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How To Play"
            android:textSize="40sp"
            android:fontFamily="@font/difficulty"
            android:textColor="@color/text_primary"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <TextView
            android:id="@+id/tvInstructionPopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font"
            android:paddingBottom="24dp"
            android:text="Instructions on How to Play..."
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="4dp"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSingleWordPopup"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SINGLE WORD MODE"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/pro_blue_primary"
                app:cornerRadius="12dp"
                app:elevation="0dp"
                android:fontFamily="@font/font"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnParagraphPopup"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="PARAGRAPH MODE"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/pro_blue_primary"
                app:cornerRadius="12dp"
                app:elevation="0dp"
                android:fontFamily="@font/font"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>