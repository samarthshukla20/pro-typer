<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PLAYER PROFILE"
            android:textColor="@color/pro_blue_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/profile_card_bg"
            app:strokeWidth="2dp"
            app:strokeColor="@color/profile_stroke">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivCurrentBadge"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/ic_keystroke"
                        android:layout_gravity="center"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/tvPlayerTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="Unranked"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/profile_text_main"
                            android:fontFamily="@font/difficulty" />

                        <TextView
                            android:id="@+id/tvRankUpHint"
                            android:layout_gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Level 1 · Rank up at 500 XP"
                            android:textSize="13sp"
                            android:textColor="@color/profile_text_sub" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/tvXpEarned"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 XP earned"
                        android:textColor="@color/profile_text_main"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvXpRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 XP to go"
                        android:textColor="@color/profile_text_sub"
                        android:textSize="12sp"
                        android:layout_gravity="end"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/xpProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:progressTint="@color/pro_blue_primary"
                    android:progressBackgroundTint="@color/profile_stroke"
                    android:progress="0"
                    android:max="100" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RANK TIERS"
            android:textColor="@color/pro_blue_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="12dp" />

        <HorizontalScrollView
            android:id="@+id/rankScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="12dp"
            android:clipToPadding="false"
            android:paddingStart="0dp"
            android:paddingEnd="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTierKeystroke"
                    android:layout_width="200dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_keystroke"
                            android:scaleType="fitCenter"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Keystroke"
                                android:textColor="@color/pro_blue_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:id="@+id/tvRangeKeystroke"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lv. 1–10"
                                android:textColor="@color/profile_text_sub"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTierSprinter"
                    android:layout_width="200dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_sprinter"
                            android:scaleType="fitCenter"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sprinter"
                                android:textColor="#2563EB"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:id="@+id/tvRangeSprinter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lv. 11–20"
                                android:textColor="@color/profile_text_sub"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTierVelocity"
                    android:layout_width="200dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_velocity"
                            android:scaleType="fitCenter"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Velocity"
                                android:textColor="#EA580C"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:id="@+id/tvRangeVelocity"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lv. 21–30"
                                android:textColor="@color/profile_text_sub"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTierSupersonic"
                    android:layout_width="200dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_supersonic"
                            android:scaleType="fitCenter"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Supersonic"
                                android:textColor="#D97706"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:id="@+id/tvRangeSupersonic"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lv. 31–40"
                                android:textColor="@color/profile_text_sub"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTierLightspeed"
                    android:layout_width="200dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_lightspeed"
                            android:scaleType="fitCenter"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lightspeed"
                                android:textColor="#0891B2"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1" />
                            <TextView
                                android:id="@+id/tvRangeLightspeed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lv. 41+"
                                android:textColor="@color/profile_text_sub"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </HorizontalScrollView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LIFETIME STATS"
            android:textColor="@color/pro_blue_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Top Speed"
                            android:textColor="@color/pro_blue_primary"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvProfileTopSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- WPM"
                            android:textColor="@color/profile_text_main"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avg. Speed"
                            android:textColor="@color/pro_blue_primary"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvProfileAvgSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/profile_text_main"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Matches"
                            android:textColor="@color/pro_blue_primary"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvProfileMatches"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/profile_text_main"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="100dp"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/profile_card_bg"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/profile_stroke">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Win Rate"
                            android:textColor="@color/pro_blue_primary"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tvProfileWinRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-- %"
                            android:textColor="@color/pro_accent"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="80dp">

            <ImageButton
                android:id="@+id/btnHowToPlay"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/htp"
                android:background="@drawable/circle_outline"
                android:backgroundTint="@color/profile_card_bg"
                app:tint="@color/pro_blue_primary"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:layout_marginEnd="24dp"
                android:elevation="6dp"/>

            <ImageButton
                android:id="@+id/btnAbout"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/about"
                android:background="@drawable/circle_outline"
                android:backgroundTint="@color/profile_card_bg"
                app:tint="@color/pro_blue_primary"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:elevation="6dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>