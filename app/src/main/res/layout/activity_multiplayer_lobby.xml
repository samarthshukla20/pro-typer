<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Top title -->
    <TextView
        android:id="@+id/lobbyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Multiplayer Arena"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="@font/font"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="36dp"/>

    <!-- Center: button + status text -->
    <LinearLayout
        android:id="@+id/centerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/lobbyTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Status text with animated dots -->
        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="Ready to find a match"
            android:textSize="16sp"
            android:fontFamily="@font/difficulty"
            android:textColor="?attr/colorOnSurface"/>

        <!-- Main Find Match button (no ring behind) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/findMatchButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find Match"
            android:textSize="18sp"
            android:fontFamily="@font/difficulty"
            android:textColor="?attr/colorOnPrimary"
            app:cornerRadius="999dp"
            app:backgroundTint="?attr/colorPrimary"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:elevation="6dp"/>

        <!-- Rules button in top-right -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/rulesButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rules"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:fontFamily="@font/difficulty"
            android:padding="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="0dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>