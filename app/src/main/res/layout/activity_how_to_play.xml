<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/howToPlayOverlay">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardModeSelection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/pro_blue_primary"
        app:strokeWidth="2dp"
        app:cardBackgroundColor="@color/bg_card"
        android:layout_gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How To Play"
                android:textSize="40sp"
                android:fontFamily="@font/difficulty"
                android:textColor="@color/text_primary"
                android:layout_gravity="center_horizontal"
                android:paddingBottom="24dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSingleWord"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SINGLE WORD MODE"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/pro_blue_primary"
                android:fontFamily="@font/font"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnParagraphPopup"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="PARAGRAPH MODE"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/pro_blue_primary"
                android:fontFamily="@font/font"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInstruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/pro_blue_primary"
        app:strokeWidth="2dp"
        app:cardBackgroundColor="@color/bg_card"
        android:layout_gravity="center"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Instructions go here..."
                android:textSize="16sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/font"
                android:textColor="@color/text_primary"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</FrameLayout>