<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="@color/howToPlayOverlay"
    android:clickable="false"
    android:focusable="false"
    android:id="@+id/gameOverContainer">

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:gravity="center_horizontal"
        android:padding="20dp"
        android:orientation="vertical"
        android:layout_gravity="center">

        <TextView
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:layout_marginBottom="20dp"
            android:textSize="40sp"
            android:fontFamily="@font/font"
            android:textColor="#EF4444"
            android:id="@+id/gameOverTitle"
            android:text="GAME OVER"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_height="wrap_content"
            android:layout_width="320dp"
            android:layout_marginBottom="40dp"
            app:strokeColor="@color/pro_blue_primary"
            app:strokeWidth="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:cardBackgroundColor="@color/bg_card"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/Widget.MaterialComponents.CardView"
            android:layout_marginTop="20dp"
            app:cardElevation="0dp"
            app:cardCornerRadius="24dp"
            android:id="@+id/mainGameOverCard">

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:gravity="center_horizontal"
                android:paddingBottom="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:textSize="22sp"
                    android:fontFamily="@font/difficulty"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="24dp"
                    android:id="@+id/gameOverMessageInside"
                    android:text="Time's Up!"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    app:strokeColor="@color/border_unfocused"
                    app:strokeWidth="1dp"
                    android:padding="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    android:layout_marginTop="20dp"
                    style="@style/Widget.MaterialComponents.CardView"
                    app:cardCornerRadius="16dp"
                    android:id="@+id/scoreCard">

                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_height="20dp"
                            android:layout_width="20dp"
                            android:src="@drawable/accuracy" />

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textSize="20sp"
                            android:fontFamily="@font/difficulty"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="8dp"
                            android:id="@+id/scoreTextInsideCard"
                            android:text="Accuracy: 0%"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    app:strokeColor="@color/border_unfocused"
                    app:strokeWidth="1dp"
                    android:padding="14dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/bg_card"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="24dp"
                    style="@style/Widget.MaterialComponents.CardView"
                    app:cardCornerRadius="16dp"
                    android:id="@+id/wpmCard">

                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:padding="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_height="20dp"
                            android:layout_width="20dp"
                            android:src="@drawable/wpm" />

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:textSize="20sp"
                            android:fontFamily="@font/difficulty"
                            android:textColor="@color/text_primary"
                            android:layout_marginStart="8dp"
                            android:id="@+id/wpmTextView"
                            android:text="WPM: 0"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="24dp"
                    android:paddingHorizontal="32dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/baseXpText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Base XP: +0"
                            android:textColor="@color/text_secondary"
                            android:textSize="15sp"
                            android:fontFamily="@font/difficulty" />

                        <TextView
                            android:id="@+id/completionXpText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Completion: +20"
                            android:textColor="@color/pro_accent"
                            android:textSize="15sp"
                            android:visibility="gone"
                            android:fontFamily="@font/difficulty" />

                        <TextView
                            android:id="@+id/speedXpText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Speed Bonus: +15"
                            android:textColor="@color/pro_accent"
                            android:textSize="15sp"
                            android:visibility="gone"
                            android:fontFamily="@font/difficulty" />

                        <TextView
                            android:id="@+id/adXpText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ad Vault: +10"
                            android:textColor="#FF9800"
                            android:textSize="15sp"
                            android:visibility="gone"
                            android:textStyle="bold"
                            android:fontFamily="@font/difficulty" />

                        <View
                            android:layout_width="120dp"
                            android:layout_height="1dp"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="6dp"
                            android:background="@color/border_unfocused" />

                        <TextView
                            android:id="@+id/xpEarnedText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total: + 0 XP"
                            android:textColor="@color/pro_accent"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/difficulty" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/xpProgressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="14dp"
                        android:progressTint="@color/pro_accent"
                        android:progressBackgroundTint="@color/border_unfocused"
                        android:progress="0"
                        android:max="100" />

                    <TextView
                        android:id="@+id/levelInfoText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Level 1 (0 / 500 XP)"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/difficulty"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:minWidth="110dp"
                        android:layout_marginEnd="16dp"
                        android:textSize="18sp"
                        android:fontFamily="@font/difficulty"
                        app:cornerRadius="50dp"
                        app:elevation="0dp"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/pro_blue_primary"
                        style="@style/Widget.Material3.Button"
                        android:id="@+id/menuButton"
                        android:text="Menu" />

                    <com.google.android.material.button.MaterialButton
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:minWidth="110dp"
                        android:textSize="18sp"
                        android:fontFamily="@font/difficulty"
                        app:cornerRadius="50dp"
                        app:elevation="0dp"
                        android:textColor="@android:color/white"
                        app:backgroundTint="@color/pro_blue_primary"
                        style="@style/Widget.Material3.Button"
                        android:layout_marginStart="16dp"
                        android:id="@+id/retryButton"
                        android:text="Retry" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</FrameLayout>