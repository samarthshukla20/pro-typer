<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="?attr/colorSurface">

    <!-- TINTED OVERLAY BACKGROUND -->
    <View
        android:id="@+id/countdownDimBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#B3000000"
        android:elevation="9dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CENTERED COUNTDOWN TEXT -->
    <TextView
        android:id="@+id/countdownText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:fontFamily="@font/difficulty"
        android:textColor="#4A5568"
        android:textSize="40sp"
        android:textStyle="bold"
        android:visibility="gone"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TOP BAR: Timer + Title + Two Progress Bars -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBarCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:strokeColor="?attr/colorOnPrimaryContainer"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Row: Timer + Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/multiplayerTimerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time left: 120s"
                    android:textSize="16sp"
                    android:fontFamily="@font/difficulty"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/matchTitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Multiplayer Arena"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/difficulty"
                    android:textColor="?attr/colorOnPrimaryContainer" />
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp" />

            <!-- Row: You Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/youLabel"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="You"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/difficulty"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <ProgressBar
                    android:id="@+id/myProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="?attr/colorOnPrimaryContainer"
                    android:backgroundTint="#33000000"
                    android:indeterminate="false"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- Row: Opponent Progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <TextView
                    android:id="@+id/opponentLabel"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Opponent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/difficulty"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <ProgressBar
                    android:id="@+id/opponentProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="?attr/colorOnPrimaryContainer"
                    android:backgroundTint="#33000000"
                    android:indeterminate="false"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- PARAGRAPH CARD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/paragraphCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:strokeColor="?attr/colorOnSurface"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/topBarCard"
        app:layout_constraintBottom_toTopOf="@id/inputCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/paragraphScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <TextView
                android:id="@+id/multiplayerWordDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading paragraph..."
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"
                android:fontFamily="@font/difficulty"
                android:textColor="?attr/colorOnSurface" />
        </ScrollView>

    </com.google.android.material.card.MaterialCardView>

    <!-- INPUT CARD / TYPING AREA -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/inputCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        app:strokeColor="?attr/colorOnPrimaryContainer"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/inputLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type here:"
                android:textSize="14sp"
                android:fontFamily="@font/difficulty"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/multiplayerInputField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="@android:color/transparent"
                android:hint="Start typing the paragraph..."
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:fontFamily="@font/difficulty"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:textColorHint="@android:color/darker_gray"
                android:textSize="16sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
