<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/bg_main">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBarCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_card"
        app:strokeColor="@color/border_unfocused"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/multiplayerTimerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time left: 120s"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/difficulty"
                    android:textColor="@color/pro_blue_primary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/matchTitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Multiplayer Arena"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/difficulty"
                    android:textColor="@color/text_primary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/youLabel"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="You"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/difficulty"
                    android:textColor="@color/text_primary" />

                <ProgressBar
                    android:id="@+id/myProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/pro_blue_primary"
                    android:backgroundTint="@color/border_unfocused"
                    android:indeterminate="false"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/opponentLabel"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Opponent"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/difficulty"
                    android:textColor="@color/text_secondary" />

                <ProgressBar
                    android:id="@+id/opponentProgressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="10dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="4dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/text_secondary"
                    android:backgroundTint="@color/border_unfocused"
                    android:indeterminate="false"
                    android:layout_weight="1" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/paragraphCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_card"
        app:strokeColor="@color/border_unfocused"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/topBarCard"
        app:layout_constraintBottom_toTopOf="@id/inputCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/paragraphScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <TextView
                android:id="@+id/multiplayerWordDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading paragraph..."
                android:textSize="20sp"
                android:lineSpacingExtra="6dp"
                android:fontFamily="@font/difficulty"
                android:textColor="@color/text_primary" />
        </ScrollView>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/inputCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/bg_card"
        app:strokeColor="@color/pro_blue_primary"
        app:strokeWidth="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/inputLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TYPE HERE"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="@font/difficulty"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/multiplayerInputField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="@android:color/transparent"
                android:hint="Start typing the paragraph..."
                android:maxLines="4"
                android:inputType="textMultiLine|textNoSuggestions"
                android:gravity="top|start"
                android:fontFamily="@font/difficulty"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="18sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>